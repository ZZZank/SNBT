{
  "name": "snbt",
  "displayName": "SNBT",
  "description": "SNBT Language support",
  "version": "0.0.1",
  "main": "./out/src/extension.js",
  "activationEvents": [],
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "commands": [
      {
        "command": "snbt.toggleLenientMode",
        "title": "SNBT: Toggle Lenient Mode"
      }
    ],
    "configuration": {
      "title": "SNBT",
      "properties": {
        "snbt.lenient": {
          "type": "boolean",
          "default": false,
          "description": "允许换行符代替逗号作为列表/复合标签/数组中的元素分隔符"
        },
        "snbt.format.indentSize": {
          "type": "number",
          "default": 4,
          "minimum": 1,
          "maximum": 16,
          "description": "格式化缩进大小"
        },
        "snbt.format.useTabs": {
          "type": "boolean",
          "default": false,
          "description": "使用制表符缩进，否则使用空格"
        }
      }
    },
    "languages": [
      {
        "id": "snbt",
        "aliases": [
          "SNBT",
          "snbt"
        ],
        "extensions": [
          ".snbt"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "snbt",
        "scopeName": "source.snbt",
        "path": "./syntaxes/snbt.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/vscode": "^1.120.0",
    "typescript": "^5.7.0"
  }
}
